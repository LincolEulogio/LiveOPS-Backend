# ─────────────────────────────────────────────────────────────────────────────
# LIVEOPSFIN — Backend environment variables
#
# Copy this file to .env and fill in the real values.
# NEVER commit .env with real credentials to version control.
#
# Production secret management: use Vault, AWS Secrets Manager, or
# Docker secrets — do not pass secrets via plain env files in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────────────────────
# For docker-compose the URL is overridden to the internal service hostname.
DATABASE_URL=postgresql://liveops_user:CHANGE_ME@localhost:5433/liveops_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=CHANGE_ME_32_BYTES_BASE64

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001

# ── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ── AI — Google Gemini ───────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME

# ── LiveKit (WebRTC) ─────────────────────────────────────────────────────────
# https://cloud.livekit.io
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
LIVEKIT_URL=wss://your-project.livekit.cloud

# ── UploadThing (file storage) ───────────────────────────────────────────────
# https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=CHANGE_ME

# ── VAPID (Web Push) ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_EMAIL=admin@yourdomain.com
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# ── Restream ─────────────────────────────────────────────────────────────────
RESTREAM_WEBHOOK_SECRET=CHANGE_ME
RESTREAM_CLIENT_ID=CHANGE_ME
RESTREAM_CLIENT_SECRET=CHANGE_ME
RESTREAM_REDIRECT_URI=http://localhost:4000/api/v1/social/restream/callback

# ── OAuth — Google ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
# https://github.com/settings/apps
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback
