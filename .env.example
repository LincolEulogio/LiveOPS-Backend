# LIVEOPSFIN backend environment variables
# Copy this file to .env and fill in the real values.
# Never commit .env with real credentials.

# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/liveops

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=CHANGE_ME_32_BYTES_BASE64

# CORS
CORS_ORIGIN=http://localhost:4000
FRONTEND_URL=http://localhost:4000

# AI
GEMINI_API_KEY=CHANGE_ME

# LiveKit
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
LIVEKIT_INTERNAL_URL=ws://localhost:7880
LIVEKIT_PUBLIC_URL=ws://localhost:7880
LIVEKIT_URL=ws://localhost:7880

# UploadThing
UPLOADTHING_TOKEN=CHANGE_ME

# VAPID
VAPID_EMAIL=admin@yourdomain.com
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME

# SMTP
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME

# Restream
RESTREAM_WEBHOOK_SECRET=CHANGE_ME
RESTREAM_CLIENT_ID=CHANGE_ME
RESTREAM_CLIENT_SECRET=CHANGE_ME
RESTREAM_REDIRECT_URI=http://localhost:5000/api/v1/social/restream/callback

# OAuth Google
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# OAuth GitHub
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# SRS
SRS_API_URL=http://localhost:1985
SRS_RTMP_HOST=localhost
SRS_RTMP_PORT=1935
SRS_HLS_PORT=8080
